# Copy to .env and edit. Used by docker-compose.yml.

# Path on the host to your MP3 collection. Mounted read-only into the generator
# so it can read ID3 tags + cover art. Required.
MP3_DIR=/mnt/nas/mp3

# External URL where those same MP3 files are already served to browsers. This
# container does NOT serve the audio — only the generated gallery. Required.
# Folder/file names are appended to this, e.g. PUBLIC_PATH/Album/track.mp3
PUBLIC_PATH=https://music.example.com/mp3/

# Host port to expose the gallery on (http://localhost:PORT).
PORT=8080

# How often (seconds) to regenerate the gallery to pick up new music.
# Use 0 to generate once and exit.
REFRESH_INTERVAL=3600

# Gallery appearance.
SITE_NAME=MP3 Gallery
SITE_LOGO=🎵
DOWNLOAD_ICON=⬇

# Generate downsized 480px cover thumbnails for faster loads (true/false).
GENERATE_THUMBNAILS=true
